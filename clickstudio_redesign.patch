 import type { SupabaseClient } from '@supabase/supabase-js'
 
-let _client: SupabaseClient | null = null
+// ─── Mock Supabase Client for Offline/Local Fallback ───
+class MockSupabaseClient {
+  from(table: string) {
+    return {
+      upsert: async (data: any) => {
+        const items = JSON.parse(localStorage.getItem(`mock_${table}`) || '[]');
+        if (Array.isArray(data)) {
+          data.forEach(item => {
+            const idx = items.findIndex((x: any) => x.id === item.id);
+            if (idx > -1) items[idx] = { ...items[idx], ...item, updated_at: new Date().toISOString() };
+            else items.push({ ...item, created_at: new Date().toISOString(), updated_at: new Date().toISOString() });
+          });
+        } else {
+          const idx = items.findIndex((x: any) => x.id === data.id);
+          if (idx > -1) items[idx] = { ...items[idx], ...data, updated_at: new Date().toISOString() };
+          else items.push({ ...data, created_at: new Date().toISOString(), updated_at: new Date().toISOString() });
+        }
+        localStorage.setItem(`mock_${table}`, JSON.stringify(items));
+        return { data, error: null };
+      },
+      insert: async (data: any) => {
+        const items = JSON.parse(localStorage.getItem(`mock_${table}`) || '[]');
+        if (Array.isArray(data)) {
+          data.forEach(item => {
+            items.push({ ...item, id: item.id || Math.random().toString(), created_at: new Date().toISOString() });
+          });
+        } else {
+          items.push({ ...data, id: data.id || Math.random().toString(), created_at: new Date().toISOString() });
+        }
+        localStorage.setItem(`mock_${table}`, JSON.stringify(items));
+        return { data, error: null };
+      },
+      select: (query: string = '*') => {
+        let items = JSON.parse(localStorage.getItem(`mock_${table}`) || '[]');
+
+        // Relation join: sessions -> photos
+        if (table === 'sessions' && query.includes('photos')) {
+          const photos = JSON.parse(localStorage.getItem('mock_photos') || '[]');
+          items = items.map((s: any) => ({
+            ...s,
+            photos: photos.filter((p: any) => p.session_id === s.id)
+          }));
+        }
+
+        const builder = {
+          eq: (field: string, value: any) => {
+            items = items.filter((x: any) => x[field] === value);
+            return builder;
+          },
+          order: (field: string, options: any) => {
+            items.sort((a: any, b: any) => {
+              const valA = a[field];
+              const valB = b[field];
+              if (options?.ascending) return valA > valB ? 1 : -1;
+              return valA < valB ? 1 : -1;
+            });
+            return builder;
+          },
+          limit: (num: number) => {
+            items = items.slice(0, num);
+            return builder;
+          },
+          single: async () => {
+            return { data: items[0] || null, error: items[0] ? null : new Error('Row not found') };
+          },
+          then: (onfulfilled: any) => {
+            return Promise.resolve({ data: items, error: null }).then(onfulfilled);
+          }
+        };
+        return builder;
+      },
+      delete: () => {
+        let items = JSON.parse(localStorage.getItem(`mock_${table}`) || '[]');
+        const builder = {
+          eq: async (field: string, value: any) => {
+            items = items.filter((x: any) => x[field] !== value);
+            localStorage.setItem(`mock_${table}`, JSON.stringify(items));
+
+            if (table === 'sessions' && field === 'id') {
+              let photos = JSON.parse(localStorage.getItem('mock_photos') || '[]');
+              photos = photos.filter((p: any) => p.session_id !== value);
+              localStorage.setItem('mock_photos', JSON.stringify(photos));
+            }
+            return { error: null };
+          }
+        };
+        return builder;
+      }
+    };
+  }
+
+  storage = {
+    from: (bucket: string) => {
+      return {
+        upload: async (path: string, blob: Blob, _options?: any) => {
+          const reader = new FileReader();
+          const base64Promise = new Promise<string>((resolve) => {
+            reader.onloadend = () => resolve(reader.result as string);
+            reader.readAsDataURL(blob);
+          });
+          const base64 = await base64Promise;
+
+          const storage = JSON.parse(localStorage.getItem(`mock_storage_${bucket}`) || '{}');
+          storage[path] = base64;
+          localStorage.setItem(`mock_storage_${bucket}`, JSON.stringify(storage));
+
+          return { data: { path }, error: null };
+        },
+        getPublicUrl: (path: string) => {
+          const storage = JSON.parse(localStorage.getItem(`mock_storage_${bucket}`) || '{}');
+          const base64 = storage[path] || '';
+          return { data: { publicUrl: base64 } };
+        },
+        remove: async (paths: string[]) => {
+          const storage = JSON.parse(localStorage.getItem(`mock_storage_${bucket}`) || '{}');
+          paths.forEach(p => delete storage[p]);
+          localStorage.setItem(`mock_storage_${bucket}`, JSON.stringify(storage));
+          return { data: null, error: null };
+        }
+      };
+    }
+  };
+}
+
+let _client: any = null;
 
 export function getClient(): SupabaseClient {
   if (!_client) {
     if (!supabaseUrl || !supabaseAnonKey) {
-      throw new Error('Supabase env vars not configured')
+      console.warn('Supabase env vars not configured. Using localStorage mock client.');
+      _client = new MockSupabaseClient() as any;
+    } else {
+      _client = createClient(supabaseUrl, supabaseAnonKey, {
+        auth: { persistSession: true, autoRefreshToken: true },
+      });
     }
-    _client = createClient(supabaseUrl, supabaseAnonKey, {
-      auth: { persistSession: true, autoRefreshToken: true },
-    })
   }
-  return _client
+  return _client as SupabaseClient;
 }
 
