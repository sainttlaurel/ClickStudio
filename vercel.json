{
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/robots\\.txt",
      "dest": "/api/robots"
    },
    {
      "src": "/sitemap\\.xml",
      "dest": "/api/sitemap"
    },
    {
      "src": "/(google[a-z0-9]+\\.html)",
      "dest": "/api/google-verification"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=*, microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
